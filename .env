# 服务器配置
PORT=3000
NODE_ENV=development

# MongoDB 配置
MONGODB_URI=mongodb://127.0.0.1:27017/my_admin
MONGODB_DB_NAME=my_admin

# PostgreSQL 配置（如无需使用可删除）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=my_admin
# DB_USER=postgres
# DB_PASSWORD=your_password

# JWT配置
JWT_SECRET=615b2c65-1564-495b-9387-72fb0bacf832
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=615b2c65-1564-495b-9387-72fb0bacf836  # 可选，用于刷新token
JWT_REFRESH_EXPIRES_IN=7d

# API配置
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3001

# 限流配置
RATE_LIMIT_WINDOW_MS=900000  # 15分钟（毫秒）
RATE_LIMIT_MAX=100            # 通用最大请求数

LOGIN_LIMIT_WINDOW_MS=900000  # 登录限流时间窗口（15分钟）
LOGIN_LIMIT_MAX=5             # 登录最大尝试次数

REGISTER_LIMIT_WINDOW_MS=3600000  # 注册限流时间窗口（1小时）
REGISTER_LIMIT_MAX=3              # 注册最大次数
